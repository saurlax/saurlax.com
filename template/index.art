{{extend 'default'}}

{{block 'head'}}
<link rel="stylesheet" href="/index.css" />
{{/block}}

{{block 'body'}}
<div class="content">
  {{@content}}

  {{each Object.values(source)
  .filter(post => post.path.startsWith('posts'))
  .sort((a, b) => Date.parse(b.metadata.date) - Date.parse(a.metadata.date))
  }}
  <div class="post">
    <div>
      <a class="post-title" href="{{ $value.link }}">{{ $value.metadata.title }}</a>
      <span class="post-date">{{$value.metadata.date.toLocaleDateString('zh')}}</span>
    </div>
    <div class="post-abstract">{{@$value.content.replace(/<[^<>]+>/g, '').slice(0, 100)}}...</div>
  </div>
  {{/each}}
</div>
{{/block}}