<!DOCTYPE html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Saurlax</title>
  </head>
  <body>
    {{@content}}
    <div><a href="/about.html">About</a><br /></div>
    {{each source}}
    {{if $value.path.startsWith('posts')}}
    <div>
      <a href="{{ $value.link }}">{{ $value.metadata.title }}</a>
      <div>{{@$value.content.replace(/<[^<>]+>/g, '').slice(0, 100)}}...</div>
    </div>
    <br />
    {{/if}}
    {{/each}}
  </body>
</html>
