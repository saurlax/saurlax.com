{{extend '../default'}}

{{block 'title'}}
{{metadata.title}} - Saurlax
{{/block}}

{{block 'body'}}
<a href="/">&lt; back to index</a>
<h1>{{ metadata.title }}</h1>
<div>
  <div>Time: {{ metadata.date.toLocaleString() }}</div>
  <div>Categories: {{ metadata.categories.join(', ') }}</div>
  <div>Tags: {{ metadata.tags.join(', ') }}</div>
</div>
{{@content}}
<a href="/">&lt; back to index</a>
{{/block}}